{
  "name": "@stotles/nestjs-graphql-zod",
  "version": "4.0.0",
  "description": "A library for integrating zod validation objects into nestjs graphql objects.",
  "keywords": [
    "decorator",
    "graphql",
    "nestjs",
    "resolver",
    "validation",
    "zod"
  ],
  "homepage": "https://github.com/Stotles/nestjs-graphql-zod#readme",
  "bugs": {
    "url": "https://github.com/Stotles/nestjs-graphql-zod/issues"
  },
  "license": "MPL-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Stotles/nestjs-graphql-zod.git"
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "fmt": "oxfmt",
    "fmt:check": "oxfmt --check",
    "lint": "oxlint",
    "lint:github": "oxlint --format=github",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc -p tests/tsconfig.json",
    "prepublish": "tsc",
    "build": "tsc",
    "build-watch": "tsc --watch",
    "release": "release-it"
  },
  "devDependencies": {
    "@nestjs/common": "^11.0.0",
    "@nestjs/graphql": "^13.0.0",
    "@swc/core": "^1.15.33",
    "@types/node": "^24.12.4",
    "class-transformer": "^0.5.1",
    "graphql": "^16.12.0",
    "oxfmt": "^0.49.0",
    "oxlint": "^1.67.0",
    "oxlint-tsgolint": "^0.23.0",
    "reflect-metadata": "^0.2.0",
    "release-it": "*",
    "typescript": "^6.0.0",
    "unplugin-swc": "^1.5.9",
    "vitest": "^4.1.0",
    "zod": "^4.3.6"
  },
  "peerDependencies": {
    "@nestjs/common": ">= 11.0",
    "@nestjs/graphql": ">= 13.0",
    "class-transformer": ">= 0.5.1",
    "graphql": ">= 16.3.0",
    "zod": ">= 4.0"
  },
  "engines": {
    "node": ">=20.19"
  },
  "allowScripts": {
    "fsevents@2.3.3": true,
    "@swc/core@1.15.33": true,
    "@nestjs/core": false
  }
}
