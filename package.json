  "description": "A library for integrating zod validation objects into nestjs graphql objects.",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "test": "vitest run && npm run test:types",
    "test:watch": "vitest",
    "test:types": "tsc -p tsconfig.test.json",
