{
  "$schema": "./node_modules/oxlint/configuration_schema.json",
  "plugins": ["eslint", "typescript", "unicorn", "oxc", "import"],
  "categories": {
    "correctness": "error",
    "perf": "error"
  },
  "rules": {
    "no-shadow": "error",
    "no-unnecessary-type-assertion": "error"
  },
  "env": {
    "builtin": true
  },
  "options": {
    "typeAware": true
  }
}
