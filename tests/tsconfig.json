{
  // Not "tsconfig.test.json" in the root so editors such as VSCode pick it up for the tests folder.
  "extends": "../tsconfig.json",
  "compilerOptions": {
    "rootDir": "..",
    "noEmit": true,
    "types": ["vitest/globals"],
    "paths": {
      "@nestjs/graphql/dist/schema-builder/storages/*": [
        "../node_modules/@nestjs/graphql/dist/schema-builder/storages/*"
      ]
    }
  },
  "include": [".", "../src", "../vitest.config.mts"],
  "exclude": ["node_modules", "dist"]
}
